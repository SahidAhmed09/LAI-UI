{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo",
    "types": ["vite/client", "./worker-configuration.d.ts"],
    // baseUrl removed — deprecated in TS 6.0. Relative path mappings in
    // `paths` resolve relative to this tsconfig automatically.
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/worker"]
}
